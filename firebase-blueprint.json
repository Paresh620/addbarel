{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A lead submission from the website contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead." },
        "email": { "type": "string", "description": "Email address of the lead." },
        "phone": { "type": "string", "description": "Phone number of the lead." },
        "company": { "type": "string", "description": "Company name." },
        "service": { "type": "string", "description": "Service requested." },
        "budget": { "type": "string", "description": "Budget range." },
        "message": { "type": "string", "description": "Project details." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission." }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": { "$ref": "Lead" },
      "description": "Collection of all lead submissions."
    }
  }
}
